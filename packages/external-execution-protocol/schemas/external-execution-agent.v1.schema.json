{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foundry-pay.local/schemas/external-execution-agent.v1.schema.json",
  "title": "ExternalExecutionAgent Protocol v1",
  "oneOf": [
    { "$ref": "#/$defs/ExternalExecutionRequest" },
    { "$ref": "#/$defs/PreparedExecution" },
    { "$ref": "#/$defs/ExecutionAuthorization" },
    { "$ref": "#/$defs/ExternalExecutionStatus" },
    { "$ref": "#/$defs/ExternalExecutionReceipt" },
    { "$ref": "#/$defs/RecoveryResult" }
  ],
  "$defs": {
    "Sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "Identifier": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"
    },
    "UtcTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "SolanaPubkey": {
      "type": "string",
      "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,44}$"
    },
    "EconomicPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "normalization_profile",
        "obligation_id",
        "network",
        "capability",
        "asset",
        "amount_base_units",
        "source",
        "destination",
        "expires_at"
      ],
      "properties": {
        "protocol_version": { "const": "1.0.0" },
        "normalization_profile": { "const": "foundry-pay-domain-v1" },
        "obligation_id": { "$ref": "#/$defs/Identifier" },
        "network": { "const": "solana:devnet" },
        "capability": { "const": "solana.spl_transfer.v1" },
        "asset": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "mint", "decimals"],
          "properties": {
            "kind": { "const": "spl-token" },
            "mint": { "$ref": "#/$defs/SolanaPubkey" },
            "decimals": { "type": "integer", "minimum": 0, "maximum": 18 }
          }
        },
        "amount_base_units": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)$"
        },
        "source": { "$ref": "#/$defs/SolanaPubkey" },
        "destination": { "$ref": "#/$defs/SolanaPubkey" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 256 },
        "expires_at": { "$ref": "#/$defs/UtcTimestamp" }
      }
    },
    "EconomicApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_id",
        "economic_plan_hash",
        "approved_by",
        "issued_at",
        "expires_at"
      ],
      "properties": {
        "approval_id": { "$ref": "#/$defs/Identifier" },
        "economic_plan_hash": { "$ref": "#/$defs/Sha256" },
        "approved_by": { "$ref": "#/$defs/Identifier" },
        "issued_at": { "$ref": "#/$defs/UtcTimestamp" },
        "expires_at": { "$ref": "#/$defs/UtcTimestamp" }
      }
    },
    "ExternalExecutionRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "protocol_version",
        "execution_request_id",
        "idempotency_key",
        "economic_plan",
        "economic_plan_hash",
        "economic_approval"
      ],
      "properties": {
        "type": { "const": "external_execution_request" },
        "protocol_version": { "const": "1.0.0" },
        "execution_request_id": { "$ref": "#/$defs/Identifier" },
        "idempotency_key": { "$ref": "#/$defs/Identifier" },
        "economic_plan": { "$ref": "#/$defs/EconomicPlan" },
        "economic_plan_hash": { "$ref": "#/$defs/Sha256" },
        "economic_approval": { "$ref": "#/$defs/EconomicApproval" }
      }
    },
    "SimulationAttestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rpc_provider_id",
        "genesis_hash",
        "slot",
        "commitment_level",
        "recent_blockhash",
        "last_valid_block_height",
        "simulated_at",
        "valid_until",
        "logs_hash",
        "pre_balances_hash",
        "post_balances_hash",
        "units_consumed",
        "fee_lamports",
        "success"
      ],
      "properties": {
        "rpc_provider_id": { "$ref": "#/$defs/Identifier" },
        "genesis_hash": { "type": "string", "minLength": 32, "maxLength": 128 },
        "slot": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "commitment_level": { "enum": ["confirmed", "finalized"] },
        "recent_blockhash": { "type": "string", "minLength": 32, "maxLength": 128 },
        "last_valid_block_height": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "simulated_at": { "$ref": "#/$defs/UtcTimestamp" },
        "valid_until": { "$ref": "#/$defs/UtcTimestamp" },
        "logs_hash": { "$ref": "#/$defs/Sha256" },
        "pre_balances_hash": { "$ref": "#/$defs/Sha256" },
        "post_balances_hash": { "$ref": "#/$defs/Sha256" },
        "accounts_observed_hash": { "$ref": "#/$defs/Sha256" },
        "programs_observed_hash": { "$ref": "#/$defs/Sha256" },
        "units_consumed": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "fee_lamports": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "success": { "type": "boolean" }
      }
    },
    "PreparedExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "protocol_version",
        "execution_request_id",
        "executor_id",
        "executor_version",
        "economic_plan_hash",
        "prepared_message_base64",
        "prepared_message_hash",
        "simulation",
        "simulation_attestation_hash",
        "execution_commitment_hash",
        "expires_at"
      ],
      "properties": {
        "type": { "const": "prepared_execution" },
        "protocol_version": { "const": "1.0.0" },
        "execution_request_id": { "$ref": "#/$defs/Identifier" },
        "executor_id": { "$ref": "#/$defs/Identifier" },
        "executor_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "economic_plan_hash": { "$ref": "#/$defs/Sha256" },
        "prepared_message_base64": { "type": "string", "minLength": 1 },
        "prepared_message_hash": { "$ref": "#/$defs/Sha256" },
        "simulation": { "$ref": "#/$defs/SimulationAttestation" },
        "simulation_attestation_hash": { "$ref": "#/$defs/Sha256" },
        "execution_commitment_hash": { "$ref": "#/$defs/Sha256" },
        "expires_at": { "$ref": "#/$defs/UtcTimestamp" }
      }
    },
    "ExecutionAuthorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "protocol_version",
        "authorization_id",
        "execution_request_id",
        "execution_commitment_hash",
        "prepared_message_hash",
        "signer",
        "single_use",
        "issued_at",
        "expires_at",
        "authorization_signature"
      ],
      "properties": {
        "type": { "const": "execution_authorization" },
        "protocol_version": { "const": "1.0.0" },
        "authorization_id": { "$ref": "#/$defs/Identifier" },
        "execution_request_id": { "$ref": "#/$defs/Identifier" },
        "execution_commitment_hash": { "$ref": "#/$defs/Sha256" },
        "prepared_message_hash": { "$ref": "#/$defs/Sha256" },
        "signer": { "$ref": "#/$defs/SolanaPubkey" },
        "single_use": { "const": true },
        "issued_at": { "$ref": "#/$defs/UtcTimestamp" },
        "expires_at": { "$ref": "#/$defs/UtcTimestamp" },
        "authorization_signature": { "type": "string", "minLength": 1 }
      }
    },
    "ExternalExecutionStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "protocol_version",
        "execution_request_id",
        "state",
        "updated_at"
      ],
      "properties": {
        "type": { "const": "external_execution_status" },
        "protocol_version": { "const": "1.0.0" },
        "execution_request_id": { "$ref": "#/$defs/Identifier" },
        "state": {
          "enum": [
            "received",
            "prepared",
            "authorized",
            "signed",
            "broadcast",
            "confirmed",
            "failed",
            "expired",
            "needs_recovery"
          ]
        },
        "transaction_signature": { "type": "string", "minLength": 32, "maxLength": 128 },
        "updated_at": { "$ref": "#/$defs/UtcTimestamp" }
      }
    },
    "ExternalExecutionReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "protocol_version",
        "execution_request_id",
        "execution_commitment_hash",
        "prepared_message_hash",
        "transaction_signature",
        "slot",
        "confirmation_status",
        "observed_at",
        "receipt_hash"
      ],
      "properties": {
        "type": { "const": "external_execution_receipt" },
        "protocol_version": { "const": "1.0.0" },
        "execution_request_id": { "$ref": "#/$defs/Identifier" },
        "execution_commitment_hash": { "$ref": "#/$defs/Sha256" },
        "prepared_message_hash": { "$ref": "#/$defs/Sha256" },
        "transaction_signature": { "type": "string", "minLength": 32, "maxLength": 128 },
        "slot": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "confirmation_status": { "enum": ["confirmed", "finalized"] },
        "observed_at": { "$ref": "#/$defs/UtcTimestamp" },
        "receipt_hash": { "$ref": "#/$defs/Sha256" }
      }
    },
    "RecoveryResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "protocol_version",
        "execution_request_id",
        "outcome",
        "may_rematerialize",
        "observed_at"
      ],
      "properties": {
        "type": { "const": "recovery_result" },
        "protocol_version": { "const": "1.0.0" },
        "execution_request_id": { "$ref": "#/$defs/Identifier" },
        "outcome": { "enum": ["confirmed", "failed_before_broadcast", "unknown"] },
        "transaction_signature": { "type": "string", "minLength": 32, "maxLength": 128 },
        "may_rematerialize": { "type": "boolean" },
        "observed_at": { "$ref": "#/$defs/UtcTimestamp" }
      }
    }
  }
}
